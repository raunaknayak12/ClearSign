# ClearSign Frontend — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.

# Backend API URL for browser requests.
# Local dev: http://localhost:8000
# Production (Vercel): leave empty to use same-origin /api proxy
NEXT_PUBLIC_API_URL=http://localhost:8000

# Client-side file size guard — must match backend MAX_FILE_SIZE_MB
NEXT_PUBLIC_MAX_FILE_MB=10
