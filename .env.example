# ============================================
# ClearSign v1.0 — Environment Variables
# ============================================
# Copy this file to backend/.env and frontend/.env.local
# Never commit actual .env files to version control.

# ── Backend (FastAPI / Cloudflare Workers) ──

# Groq API key — never expose to frontend
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Groq model identifiers — swappable without code changes
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant

# Maximum upload file size in megabytes
MAX_FILE_SIZE_MB=10

# CORS allowlist — comma-separated origins
# Development: http://localhost:3000
# Production: https://clearsign.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Environment mode — controls log verbosity
# Options: development (verbose) | production (structured JSON)
ENVIRONMENT=development

# ── Frontend (Next.js / Vercel) ──

# Backend API URL — NEXT_PUBLIC_ prefix exposes to browser bundle
# Development: http://localhost:8000
# Production: https://api.clearsign.workers.dev
NEXT_PUBLIC_API_URL=http://localhost:8000

# Client-side file size guard — must match MAX_FILE_SIZE_MB
NEXT_PUBLIC_MAX_FILE_MB=10
